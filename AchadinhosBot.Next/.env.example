# Ambiente
ASPNETCORE_ENVIRONMENT=Development

# Webhook
WEBHOOK__PORT=5000
WEBHOOK__API_KEY=CHANGE_ME_WEBHOOK_API_KEY
WEBHOOK__PUBLIC_BASE_URL=https://achadinhos.reidasofertas.ia.br

# Heartbeat + alertas
HEARTBEAT__ENABLED=true
HEARTBEAT__PING_URL=
HEARTBEAT__INTERVAL_SECONDS=60
HEARTBEAT__TIMEOUT_SECONDS=10
HEARTBEAT__TELEGRAM_ALERT_ENABLED=true
HEARTBEAT__TELEGRAM_ALERT_CHAT_ID=0
HEARTBEAT__NTFY_ALERT_ENABLED=false
HEARTBEAT__NTFY_TOPIC_URL=
HEARTBEAT__NTFY_ACCESS_TOKEN=
HEARTBEAT__NTFY_TITLE=AchadinhosBot Heartbeat
HEARTBEAT__NTFY_PRIORITY=default
HEARTBEAT__NTFY_TAGS=warning

# Auth (hashes PBKDF2)
AUTH__ADMIN__USERNAME=admin
AUTH__ADMIN__PASSWORD_HASH=pbkdf2$100000$CHANGE_ME_SALT_BASE64==$CHANGE_ME_HASH_BASE64=
AUTH__OPERATOR__USERNAME=operator
AUTH__OPERATOR__PASSWORD_HASH=pbkdf2$100000$CHANGE_ME_SALT_BASE64==$CHANGE_ME_HASH_BASE64=

# Evolution (WhatsApp)
EVOLUTION__BASE_URL=http://localhost:8082
EVOLUTION__API_KEY=CHANGE_ME_EVOLUTION_API_KEY
EVOLUTION__INSTANCE_NAME=ZapOfertas
EVOLUTION__WEBHOOK_SECRET=CHANGE_ME_EVOLUTION_WEBHOOK_SECRET

# Telegram
TELEGRAM__BOT_TOKEN=
TELEGRAM__API_ID=0
TELEGRAM__API_HASH=
TELEGRAM__DESTINATION_CHAT_ID=0
TELEGRAM__LOGS_CHAT_ID=0
TELEGRAM__USERBOT_PHONE=

# Affiliate
AFFILIATE__AMAZON_TAG=
AFFILIATE__SHEIN_ID=
AFFILIATE__SHEIN_CODE=
AFFILIATE__SHOPEE_APP_ID=
AFFILIATE__SHOPEE_SECRET=
AFFILIATE__MERCADOLIVRE_MATT_TOOL=
AFFILIATE__MERCADOLIVRE_MATT_WORD=
AFFILIATE__MERCADOLIVRE_CLIENT_ID=
AFFILIATE__MERCADOLIVRE_CLIENT_SECRET=
AFFILIATE__MERCADOLIVRE_REFRESH_TOKEN=
AFFILIATE__MERCADOLIVRE_USER_ID=
AFFILIATE__MERCADOLIVRE_REQUIRE_OAUTH=false
AFFILIATE__AMAZONCREATORAPI__ENABLED=false
AFFILIATE__AMAZONCREATORAPI__CLIENTID=
AFFILIATE__AMAZONCREATORAPI__CLIENTSECRET=
AFFILIATE__AMAZONCREATORAPI__TOKENENDPOINT=https://api.amazon.com/auth/o2/token
AFFILIATE__AMAZONCREATORAPI__SCOPE=
AFFILIATE__AMAZONCREATORAPI__LINKENDPOINT=
AFFILIATE__AMAZONCREATORAPI__METHOD=POST
AFFILIATE__AMAZONCREATORAPI__PAYLOADJSON={"url":"{{url}}","partnerTag":"{{partnerTag}}"}
