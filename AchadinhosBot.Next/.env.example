# Auth (hashes PBKDF2)
AUTH__ADMIN__USERNAME=admin
AUTH__ADMIN__PASSWORD_HASH=pbkdf2$100000$CHANGE_ME_SALT_BASE64==$CHANGE_ME_HASH_BASE64=
AUTH__OPERATOR__USERNAME=operator
AUTH__OPERATOR__PASSWORD_HASH=pbkdf2$100000$CHANGE_ME_SALT_BASE64==$CHANGE_ME_HASH_BASE64=

# Evolution (WhatsApp)
EVOLUTION__BASE_URL=http://localhost:8082
