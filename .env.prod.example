ASPNETCORE_ENVIRONMENT=Production

# Porta do app dentro/fora do host (Cloudflare aponta para essa porta local)
WEBHOOK__PORT=5005
WEBHOOK__API_KEY=CHANGE_ME_WEBHOOK_API_KEY
WEBHOOK__PUBLICBASEURL=https://achadinhos.reidasofertas.ia.br

# Evolution compartilhado no host (Windows)
EVOLUTION__BASEURL=http://host.docker.internal:8082
EVOLUTION__APIKEY=CHANGE_ME_EVOLUTION_API_KEY
EVOLUTION__INSTANCENAME=ZapOfertas
EVOLUTION__WEBHOOKSECRET=CHANGE_ME_EVOLUTION_WEBHOOK_SECRET

# Telegram (pode manter o mesmo bot de producao)
TELEGRAM__BOTTOKEN=
TELEGRAM__APIID=0
TELEGRAM__APIHASH=
TELEGRAM__DESTINATIONCHATID=0
TELEGRAM__LOGSCHATID=0

# Destinos oficiais (usado para bloquear em dev)
OFFICIAL_WHATSAPP_GROUP_ID=120363405661434395@g.us
OFFICIAL_TELEGRAM_CHAT_ID=0

# Auth (gerar hash PBKDF2; nao usar senha em texto puro)
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORDHASH=
AUTH_OPERATOR_USERNAME=operator
AUTH_OPERATOR_PASSWORDHASH=

# Afiliados
AFFILIATE__AMAZONTAG=reidasofer022-20
AFFILIATE__SHEINID=
AFFILIATE__SHEINCODE=
AFFILIATE__MERCADOLIVREMATTTOOL=
AFFILIATE__MERCADOLIVREMATTWORD=

# RabbitMQ interno do compose
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
