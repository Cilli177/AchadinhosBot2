        "contentType": "application/json",
        "data": "{\"username\":\"admin\",\"password\":\"admin123\"}",
        "parseResponse": true,
        "timeout": "",
        "shareCookies": true,
        "ca": "",
        "rejectUnauthorized": true,
        "followRedirect": true,
        "useQuerystring": false,
        "gzip": true,
        "useMtls": false,
        "followAllRedirects": false
      },
      "metadata": {
        "designer": {
          "x": 1200,
